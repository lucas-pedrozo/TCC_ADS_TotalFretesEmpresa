# Usado automaticamente com: npm run dev:https
VITE_DEV_HOST=totalfretes.com
# Porta 443 = https://totalfretes.com (sem :porta). Requer terminal como Administrador no Windows.
# Se falhar por permissão, use VITE_DEV_HTTPS_PORT=5173 e acesse https://totalfretes.com:5173
VITE_DEV_HTTPS_PORT=443

# URL relativa evita mixed content (página HTTPS chamando API HTTP).
VITE_API_URL=/api
VITE_GATEWAY_URL=http://127.0.0.1:80
