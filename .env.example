# --- Desenvolvimento local (npm run dev) ---
VITE_API_URL=http://localhost/api
# Gateway do backend (proxy Vite em /api) — padrão: http://127.0.0.1:80
VITE_GATEWAY_URL=http://127.0.0.1:80

# --- Desenvolvimento HTTPS (npm run dev:https) ---
# 1. Adicione totalfretes.com ao arquivo hosts (veja hosts.example).
# 2. O arquivo .env.https usa https://totalfretes.com na porta 443.
# 3. No Windows, abra o terminal como Administrador (porta 443) ou use VITE_DEV_HTTPS_PORT=5173.
# 4. Adicione https://totalfretes.com nas URLs permitidas do token Mapbox, se usar mapa.

# Token público Mapbox (pk.*) para exibir o mapa no cadastro de frete — restrinja por URL no painel Mapbox.
VITE_MAPBOX_ACCESS_TOKEN=

# --- Docker produção (docker compose up --build) ---
# VITE_API_URL e VITE_GATEWAY_URL não são usados no build do container (o Dockerfile usa VITE_API_URL=/api).
# VITE_MAPBOX_ACCESS_TOKEN é passado como build arg — alterações exigem rebuild: docker compose up --build